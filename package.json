{
  "name": "grobots",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "scrape:stores": "node scripts/fetch-store-data.mjs",
    "build:lookup": "node scripts/build-lookup-data.mjs",
    "build:source-intel": "node scripts/build-source-intel.mjs",
    "predev": "npm run scrape:stores && npm run build:lookup && npm run build:source-intel",
    "prebuild": "npm run scrape:stores && npm run build:lookup && npm run build:source-intel",
    "dev": "vite",
    "dev:full": "node scripts/dev-all.mjs",
    "build:app": "tsc -b && vite build",
    "build:prod": "node scripts/refresh-kroger-data.mjs && npm run build:lookup && npm run build:source-intel && tsc -b && vite build",
    "build": "npm run build:app",
    "lint": "eslint .",
    "mcp:grocery-imessage": "node scripts/grocery-imessage-mcp.mjs",
    "notifier:diagnostics": "node scripts/notifier-diagnostics.mjs",
    "notifier:service": "node scripts/notifier-service.mjs",
    "send:summary": "node scripts/run-summary-job.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
